generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id            String        @id @default(uuid())

  userId        String
  status        OrderStatus  @default(PAYMENT_PENDING)

  paymentExpiresAt DateTime?

  userDetailSnapshot Json

  billingSnapshot Json

  paidAt        DateTime?
  processingUntil DateTime?
  shippingUntil   DateTime?
  deliveredAt     DateTime?

  returnRequestedAt     DateTime?
  returnBy               DateTime?
  returnProcessingUntil  DateTime?
  refundInitiatedAt      DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id               String   @id @default(uuid())

  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId        String
  productVariantId String

  size             Size
  quantity         Int
  priceSnapshot    Decimal

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}


enum OrderStatus {
  ORDER_CREATED
  PAYMENT_PENDING
  PAYMENT_FAILED

  ORDER_PROCESSING
  SHIPPING
  DELIVERED
  RETURN_WINDOW_OPEN
  FAILED
  PAID

  RETURN_REQUESTED
  RETURN_PROCESSING
  REFUND_INITIATED
  RETURNED_SUCCESS

  CANCELLED
  COMPLETED
}


enum Size {
  SMALL
  MEDIUM
  LARGE
}

model CheckoutSession {
  id        String @id @default(uuid())

  userId    String
  cartId    String?

  status    CheckoutSessionStatus @default(PREVIEW)

  itemsSnapshot           Json
  buyerDetailsSnapshot    Json?
  shippingDetailsSnapshot Json?
  pricingSnapshot         Json?

  orderId   String?

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

enum CheckoutSessionStatus {
  PREVIEW
  DETAILS_FILLED
  PAYMENT_PENDING
  PAID
  EXPIRED
  CANCELLED
}

