generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Seller {
  id            String        @id @default(uuid())
  userId        String

  businessName  String?
  sellerType    SellerType

  email         String
  phone         String?

  status        SellerStatus
  isVerified    Boolean       @default(false)

  kycStatus     KycStatus     @default(NOT_SUBMITTED)
  panNumber     String?
  gstNumber     String?

  address       Address?



  totalProducts Int           @default(0)
  totalOrders   Int           @default(0)
  rating        Float?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model Address {
  id        String   @id @default(uuid())

  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String

  sellerId  String   @unique
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())

  sellerId    String   // keep field, NO relation

  title       String
  description String

  category    Category

  variants    ProductVariant[]

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sellerId])
  @@index([category])
}


model ProductVariant {
  id        String   @id @default(uuid())

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  size      Size
  quantity  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size])
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SellerType {
  INDIVIDUAL
  BUSINESS
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  FAILED
}

enum Category {
  MEN
  WOMEN
  KIDS
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}
