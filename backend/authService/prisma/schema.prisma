generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  SELLER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  roles     Role[]   @default([BUYER])
  createdAt DateTime @default(now())
}
